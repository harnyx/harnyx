# --- Platform (required) ---
PLATFORM_BASE_URL=
VALIDATOR_PUBLIC_BASE_URL=

# --- Bittensor (Harnyx Subnet defaults) ---
SUBTENSOR_NETWORK=finney
SUBTENSOR_ENDPOINT=wss://entrypoint-finney.opentensor.ai:443
SUBTENSOR_NETUID=67

# Wallet selection (defaults shown; change if your wallet/hotkey names differ).
SUBTENSOR_WALLET_NAME=harnyx-validator
SUBTENSOR_HOTKEY_NAME=default

# If set, the validator will generate/verify the hotkey file inside the mounted wallet dir.
SUBTENSOR_HOTKEY_MNEMONIC=

# Optional sandbox override. Leave unset to use harnyx/harnyx-subnet-sandbox:finney.
# For staging/testnet, set SANDBOX_IMAGE=harnyx/harnyx-subnet-sandbox:testnet.
# SANDBOX_IMAGE=

# --- Evaluation concurrency ---
# Concurrent artifacts evaluated by the validator.
VALIDATOR_ARTIFACT_PARALLELISM=4
# Batch-wide task-session cap across active artifacts.
VALIDATOR_TASK_PARALLELISM=20

# --- Completed-run progress storage ---
# Completed-run execution logs are stored in the validator state volume while
# platform drains /runs pages. Keep this longer than normal platform sync delay.
VALIDATOR_RUN_PROGRESS_RETENTION_SECONDS=86400
VALIDATOR_RUN_PROGRESS_CLEANUP_INTERVAL_SECONDS=600

# --- Validator scoring/similarity LLM ---
SCORING_LLM_PROVIDER=chutes
SCORING_LLM_RETRY_ATTEMPTS=6
SCORING_LLM_RETRY_INITIAL_MS=30000
SCORING_LLM_RETRY_MAX_MS=300000
SCORING_LLM_RETRY_JITTER=0.2
CHUTES_API_KEY=
# Optional shared internal route overrides. These are not required for normal
# validator miner-task tool execution; platform tool proxy executes provider-
# backed miner tools with miner-stored credentials.
# LLM_MODEL_PROVIDER_OVERRIDES_JSON={"tool":{"google/gemma-4-31B-turbo-TEE":"custom-openai-compatible:gemma4-cloud-run-turbo"}}
# LLM_OPENAI_COMPATIBLE_ENDPOINTS_JSON=[{"id":"gemma4-cloud-run-turbo","base_url":"https://<turbo-cloud-run-service>/v1","auth":{"type":"google_id_token","audience":"https://<turbo-cloud-run-service>","credential_source":"service_account_json_b64_env","credential_env":"GCP_SERVICE_ACCOUNT_CREDENTIAL_BASE64"}}]

# --- Optional Sentry ---
# Default sends validator failures to the Harnyx-managed Sentry project.
# Clear SENTRY_DSN to disable validator error reporting.
SENTRY_DSN=https://560346a36dba1d43fc0338ba102107d3@o4511036126396416.ingest.us.sentry.io/4511071147720704
SENTRY_ENVIRONMENT=prod
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.05
